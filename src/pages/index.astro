---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/landing/Hero.astro';
import LogoCloud from '../components/landing/LogoCloud.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import Features from '../components/landing/Features.astro';
import CTA from '../components/landing/CTA.astro';

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Wagmi Fit',
      url: 'https://wagmi.fit',
      description: 'The fastest workout programming tool for independent personal trainers. Type how you think — messy, fast, shorthand — and WAGMI structures it into polished, client-ready programs instantly.',
      sameAs: [],
    },
    {
      '@type': 'WebSite',
      name: 'Wagmi Fit',
      url: 'https://wagmi.fit',
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Wagmi Fit',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      url: 'https://wagmi.fit',
      description: 'Workout programming software for independent personal trainers. Type rough notes and get polished, client-ready programs in seconds.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        description: 'Free during beta',
      },
    },
  ],
};
---

<BaseLayout
  title="Wagmi Fit — The fastest workout programming tool on the market"
  description="From rough notes to client-ready in seconds. Built for independent personal trainers."
  schema={homeSchema}
>
  <Header />
  <main>
    <Hero />
    <LogoCloud />
    <HowItWorks />
    <Features />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
