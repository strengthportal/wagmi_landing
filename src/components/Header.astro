---
import WaitlistModal from './WaitlistModal.tsx';
---

<nav class="sticky top-0 z-50 w-full border-b border-warm-border bg-card">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-semibold tracking-tighter text-ink">WAGMI FIT</a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-ink-muted">
        <a href="/#features" class="hover:text-ink transition-colors">Features</a>
        <a href="/#workflow" class="hover:text-ink transition-colors">How it Works</a>
        <a href="/#pricing" class="hover:text-ink transition-colors">Pricing</a>
        <a href="/blog/" class="hover:text-ink transition-colors">Blog</a>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <a href="#" class="hidden text-sm font-medium text-ink-muted hover:text-ink md:block transition-colors">Sign In</a>
      <WaitlistModal client:load />
      <!-- Hamburger — mobile only -->
      <button
        id="mobile-menu-toggle"
        class="flex md:hidden items-center justify-center rounded-md p-2 text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger icon -->
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <!-- Close icon -->
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-warm-border bg-card md:hidden"
  >
    <div class="flex flex-col px-6 py-4 gap-1">
      <a href="/#features" class="rounded-md px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink">Features</a>
      <a href="/#workflow" class="rounded-md px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink">How it Works</a>
      <a href="/#pricing" class="rounded-md px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink">Pricing</a>
      <a href="/blog/" class="rounded-md px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink">Blog</a>
      <div class="my-2 border-t border-warm-border"></div>
      <a href="#" class="rounded-md px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors hover:bg-parchment-alt hover:text-ink">Sign In</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a nav link is tapped
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
