---
import WaitlistForm from '../WaitlistForm.tsx';
---

<section class="relative overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24">
  <div class="mx-auto max-w-7xl px-6 text-center">
    <div class="animate-fade-in-up">
      <p class="text-base font-medium text-ink-muted tracking-wide mb-4">We're All Gonna Make It</p>

      <h1 class="mx-auto max-w-4xl text-5xl font-semibold tracking-tight text-ink md:text-7xl leading-[1.1] text-balance">
        The fastest <span class="text-cobalt">AI-powered</span> platform for personal trainers.
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-muted md:text-xl leading-relaxed">
        Program workouts, manage clients, and track progress — all at the speed you actually think. Built for independent trainers who move fast.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <WaitlistForm client:load variant="hero" />
      </div>
      <p class="mt-4 text-xs font-medium text-ink-muted">No credit card required.</p>
    </div>

    <!-- Demo Framing -->
    <p class="mt-16 text-lg text-ink-muted text-center">See it in action. Type how you actually think — we handle the rest.</p>

    <!-- Hero Mockup -->
    <div class="animate-fade-in-up delay-200 mx-auto mt-6 max-w-5xl rounded-xl border border-warm-border bg-parchment-alt p-2 sm:p-4 shadow-xl">
      <div class="rounded-lg border border-warm-border bg-card overflow-hidden flex flex-col md:flex-row h-auto md:h-[32rem]">

        <!-- Left: Raw Input Interface -->
        <div class="w-full md:w-5/12 border-b md:border-b-0 md:border-r border-warm-border flex flex-col bg-parchment-alt/50">
          <div class="border-b border-warm-border px-4 py-3 bg-card flex items-center justify-between">
            <div class="flex items-center gap-2">
              <iconify-icon icon="solar:document-text-linear" stroke-width="1.5" class="text-cobalt text-lg"></iconify-icon>
              <span class="text-sm font-medium tracking-tight text-ink">Strength - A</span>
            </div>
            <span class="text-xs text-ink-muted">4/6/26</span>
          </div>

          <div class="flex-1 relative p-0 flex flex-col">
            <textarea
              class="w-full h-full bg-transparent border-none resize-none p-5 text-sm font-mono text-ink-muted focus:ring-0 focus:outline-none leading-relaxed"
              placeholder="Type workout here..."
              disabled
            >Sarah Hypertrophy Block - Week 1
3x/week, knee friendly (db only for lower)

Day 1: Upper
db bench press 3x 8-10
seated cable rows 3x 10-12
db lat raises 4x15

Day 2: Lower
rdls 3x 8-10 (sub for squat)
bulgarian split squats 3x 8-10
leg extensions 3x12-15</textarea>
          </div>
        </div>

        <!-- Right: Generated Output UI -->
        <div class="w-full md:w-7/12 bg-card flex flex-col relative">
          <div class="absolute inset-0 bg-card/50 backdrop-blur-[1px] flex items-center justify-center z-10" style="animation: fadeOut 0.5s 1.5s forwards;">
            <div class="flex items-center gap-2 rounded-full bg-card px-4 py-2 shadow-sm border border-warm-border">
              <iconify-icon icon="solar:settings-minimalistic-linear" class="animate-spin text-cobalt"></iconify-icon>
              <span class="text-xs font-medium text-ink-muted uppercase tracking-widest">Building...</span>
            </div>
          </div>

          <div class="border-b border-warm-border px-6 py-4 flex items-center justify-between">
            <div>
              <h3 class="text-base font-medium tracking-tight text-ink">Sarah's Hypertrophy Block</h3>
              <p class="text-xs text-ink-muted mt-0.5">4 Weeks • 3x/Week • Knee-Friendly</p>
            </div>
            <div class="flex items-center gap-2">
              <button class="inline-flex h-8 items-center justify-center rounded-md border border-warm-border bg-card px-3 text-xs font-medium text-ink hover:bg-parchment-alt">Assign to Client</button>
            </div>
          </div>

          <div class="flex-1 overflow-y-auto p-6 space-y-6">
            <!-- Day 1 -->
            <div>
              <h4 class="text-sm font-medium tracking-tight text-ink mb-3 flex items-center gap-2">
                <iconify-icon icon="solar:calendar-date-linear" class="text-ink-muted"></iconify-icon>
                Day 1: Upper Body Focus
              </h4>
              <div class="rounded-lg border border-warm-border overflow-hidden">
                <div class="flex items-center justify-between px-4 py-3 bg-parchment-alt border-b border-warm-border">
                  <span class="text-sm font-medium text-ink">Dumbbell Bench Press</span>
                  <span class="text-xs text-ink-muted">3 sets &times; 8-10 reps</span>
                </div>
                <div class="flex items-center justify-between px-4 py-3 bg-card border-b border-warm-border">
                  <span class="text-sm font-medium text-ink">Seated Cable Rows</span>
                  <span class="text-xs text-ink-muted">3 sets &times; 10-12 reps</span>
                </div>
                <div class="flex items-center justify-between px-4 py-3 bg-card">
                  <span class="text-sm font-medium text-ink">Dumbbell Lateral Raises</span>
                  <span class="text-xs text-ink-muted">4 sets &times; 15 reps</span>
                </div>
              </div>
            </div>

            <!-- Day 2 -->
            <div>
              <h4 class="text-sm font-medium tracking-tight text-ink mb-3 flex items-center gap-2">
                <iconify-icon icon="solar:calendar-date-linear" class="text-ink-muted"></iconify-icon>
                Day 2: Lower Body (Knee-Friendly)
              </h4>
              <div class="rounded-lg border border-warm-border overflow-hidden">
                <div class="flex items-center justify-between px-4 py-3 bg-parchment-alt border-b border-warm-border">
                  <span class="text-sm font-medium text-ink">Romanian Deadlifts (RDLs)</span>
                  <span class="text-xs text-dusty bg-cobalt-soft border border-cobalt-soft px-2 py-0.5 rounded-full">Alt for Squat</span>
                </div>
                <div class="flex items-center justify-between px-4 py-3 bg-card border-b border-warm-border">
                  <span class="text-sm font-medium text-ink">Bulgarian Split Squats</span>
                  <span class="text-xs text-ink-muted">3 sets &times; 8-10 reps</span>
                </div>
                <div class="flex items-center justify-between px-4 py-3 bg-card">
                  <span class="text-sm font-medium text-ink">Leg Extensions</span>
                  <span class="text-xs text-ink-muted">3 sets &times; 12-15 reps</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
