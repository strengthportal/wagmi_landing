---
---

<section id="features" class="bg-slate-50 py-24 md:py-32 border-t border-slate-200">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-medium tracking-tight text-slate-900 md:text-4xl text-balance">
          Powerful features.<br />Zero bloat.
        </h2>
        <p class="mt-4 text-lg text-slate-500">
          Everything you need to run a modern coaching business, stripped of the complexity that slows you down.
        </p>
      </div>
      <div class="mt-6 md:mt-0">
        <a href="#" class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-700">
          View all features <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">

      <!-- Feature 1: Large Span — Smart Structuring Engine -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col justify-between overflow-hidden relative">
        <div class="max-w-md relative z-10">
          <div class="inline-flex items-center rounded-full border border-indigo-200 bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 mb-4">Core Innovation</div>
          <h3 class="text-2xl font-medium tracking-tight text-slate-900 mb-2">Program at the Speed of Thought</h3>
          <p class="text-sm text-slate-500 mb-6">Write workouts however you think — shorthand, full sentences, whatever. WAGMI structures it instantly into trackable programs. Just write and go.</p>
        </div>

        <!-- Code/Logic visual -->
        <div class="mt-6 rounded-xl border border-slate-200 bg-slate-900 p-4 font-mono text-xs text-slate-300 w-full md:w-[120%] shadow-lg relative z-10">
          <div class="flex gap-2 mb-3">
            <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
          </div>
          <p><span class="text-pink-400">const</span> <span class="text-blue-300">program</span> = <span class="text-indigo-300">await</span> wagmi.<span class="text-green-300">structure</span>({'{'}</p>
          <p class="pl-4">client: <span class="text-amber-300">"Sarah Connor"</span>,</p>
          <p class="pl-4">rawInput: <span class="text-amber-300">"day 1 upper. bench 3x8, cable rows 3x10, lat raises 4x15..."</span>,</p>
          <p class="pl-4">context: [<span class="text-amber-300">"mild knee pain"</span>, <span class="text-amber-300">"db only"</span>]</p>
          <p>{'}'});</p>
        </div>
      </div>

      <!-- Feature 2: Powerful Client Management -->
      <div class="col-span-1 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <iconify-icon icon="solar:users-group-rounded-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-slate-900 mb-2">Powerful Client Management</h3>
        <p class="text-sm text-slate-500 mb-6">Track progress, injuries, PRs, and notes in one unified view. Everything your client needs, organized so you never have to dig.</p>

        <!-- Mini UI: client profile card -->
        <div class="mt-auto rounded-lg border border-slate-100 bg-slate-50 overflow-hidden">
          <div class="flex items-center gap-3 px-3 py-2.5 border-b border-slate-100">
            <div class="h-7 w-7 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-medium text-indigo-700 shrink-0">S</div>
            <div>
              <p class="text-xs font-medium text-slate-800">Sarah M.</p>
              <p class="text-[10px] text-slate-400">Hypertrophy Block · Week 3</p>
            </div>
          </div>
          <div class="flex gap-1.5 px-3 py-2 border-b border-slate-100">
            <span class="text-[9px] font-medium bg-amber-50 text-amber-700 border border-amber-100 px-1.5 py-0.5 rounded-full">Knee sensitivity</span>
            <span class="text-[9px] font-medium bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded-full">DB only</span>
          </div>
          <div class="grid grid-cols-2 divide-x divide-slate-100 px-0">
            <div class="px-3 py-2">
              <p class="text-[9px] text-slate-400 uppercase tracking-wide">Squat PR</p>
              <p class="text-xs font-semibold text-slate-800">185 lb</p>
            </div>
            <div class="px-3 py-2">
              <p class="text-[9px] text-slate-400 uppercase tracking-wide">Bench PR</p>
              <p class="text-xs font-semibold text-slate-800">115 lb</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3: Exercise & Workout Libraries -->
      <div class="col-span-1 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <iconify-icon icon="solar:notebook-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-slate-900 mb-2">Your Exercises, Your Programs</h3>
        <p class="text-sm text-slate-500 mb-6">Build a custom exercise library tailored to how you coach. Save workout templates, remix them per client, and program weeks in minutes — not hours.</p>

        <!-- Mini UI: exercise list -->
        <div class="mt-auto rounded-lg border border-slate-100 bg-slate-50 overflow-hidden">
          <div class="flex items-center justify-between px-3 py-2 border-b border-slate-100">
            <span class="text-xs font-medium text-slate-700">Romanian Deadlift</span>
            <span class="text-[10px] text-slate-400">Hinge</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2 border-b border-slate-100">
            <span class="text-xs font-medium text-slate-700">Landmine Press</span>
            <span class="text-[10px] text-slate-400">Push</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2">
            <span class="text-xs font-medium text-indigo-600">+ Save as Template</span>
            <iconify-icon icon="solar:diskette-linear" class="text-indigo-400 text-sm"></iconify-icon>
          </div>
        </div>
      </div>

      <!-- Feature 4: Mobile Workout Tracking (Large Span) -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col md:flex-row items-center gap-8 overflow-hidden">
        <div class="flex-1">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
            <iconify-icon icon="solar:smartphone-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
          </div>
          <h3 class="text-2xl font-medium tracking-tight text-slate-900 mb-2">Track Workouts Anywhere</h3>
          <p class="text-sm text-slate-500 mb-4">Trainers and clients both get a mobile app for real-time workout logging. Sets, reps, RPE — captured in the moment, synced instantly.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-slate-600"><iconify-icon icon="solar:check-circle-linear" class="text-indigo-600"></iconify-icon> Real-time set logging</li>
            <li class="flex items-center gap-2 text-sm text-slate-600"><iconify-icon icon="solar:check-circle-linear" class="text-indigo-600"></iconify-icon> RPE &amp; notes per set</li>
            <li class="flex items-center gap-2 text-sm text-slate-600"><iconify-icon icon="solar:check-circle-linear" class="text-indigo-600"></iconify-icon> Instant sync across devices</li>
          </ul>
        </div>

        <!-- Phone frame mock -->
        <div class="w-full md:w-auto shrink-0 flex justify-center">
          <div class="w-44 rounded-3xl border-4 border-slate-800 bg-white shadow-xl overflow-hidden">
            <!-- Phone notch -->
            <div class="bg-slate-800 h-5 flex items-center justify-center">
              <div class="w-12 h-1.5 bg-slate-600 rounded-full"></div>
            </div>
            <!-- Screen content -->
            <div class="p-3 space-y-2">
              <p class="text-[9px] font-semibold text-slate-500 uppercase tracking-widest">Day 1 · Upper</p>
              <!-- Exercise row -->
              <div class="rounded-md bg-slate-50 border border-slate-100 px-2.5 py-2">
                <p class="text-[10px] font-medium text-slate-800 mb-1.5">Bench Press</p>
                <div class="space-y-1">
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-slate-500">Set 1 · 135 lb × 8</span>
                    <iconify-icon icon="solar:check-circle-bold" class="text-emerald-500 text-xs"></iconify-icon>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-slate-500">Set 2 · 135 lb × 8</span>
                    <iconify-icon icon="solar:check-circle-bold" class="text-emerald-500 text-xs"></iconify-icon>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-slate-400">Set 3 · — </span>
                    <div class="w-3 h-3 rounded-full border border-slate-300"></div>
                  </div>
                </div>
              </div>
              <!-- Next exercise -->
              <div class="rounded-md border border-slate-100 px-2.5 py-2 opacity-50">
                <p class="text-[10px] font-medium text-slate-800">Cable Rows</p>
                <p class="text-[9px] text-slate-400 mt-0.5">3 sets × 10-12</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
