---
---

<section id="features" class="bg-slate-50 py-24 md:py-32 border-t border-slate-200">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-medium tracking-tight text-slate-900 md:text-4xl text-balance">
          Powerful features.<br />Zero bloat.
        </h2>
        <p class="mt-4 text-lg text-slate-500">
          Everything you need to run a modern coaching business, stripped of the complexity that slows you down.
        </p>
      </div>
      <div class="mt-6 md:mt-0">
        <a href="#" class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-700">
          View all features <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">

      <!-- Feature 1: Large Span — Smart Structuring Engine -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col justify-between overflow-hidden relative">
        <div class="max-w-md relative z-10">
          <div class="inline-flex items-center rounded-full border border-indigo-200 bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700 mb-4">Core Innovation</div>
          <h3 class="text-2xl font-medium tracking-tight text-slate-900 mb-2">Smart Structuring Engine</h3>
          <p class="text-sm text-slate-500 mb-6">Our system understands human physiology, training principles, and your personal shorthand. It doesn't just copy templates—it engineers your messy notes into perfect programs.</p>
        </div>

        <!-- Code/Logic visual -->
        <div class="mt-6 rounded-xl border border-slate-200 bg-slate-900 p-4 font-mono text-xs text-slate-300 w-full md:w-[120%] shadow-lg relative z-10">
          <div class="flex gap-2 mb-3">
            <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
          </div>
          <p><span class="text-pink-400">const</span> <span class="text-blue-300">program</span> = <span class="text-indigo-300">await</span> wagmi.<span class="text-green-300">structure</span>({'{'}</p>
          <p class="pl-4">client: <span class="text-amber-300">"Sarah Connor"</span>,</p>
          <p class="pl-4">rawInput: <span class="text-amber-300">"day 1 upper. bench 3x8, cable rows 3x10, lat raises 4x15..."</span>,</p>
          <p class="pl-4">context: [<span class="text-amber-300">"mild knee pain"</span>, <span class="text-amber-300">"db only"</span>]</p>
          <p>{'}'});</p>
        </div>
      </div>

      <!-- Feature 2: Client CRM -->
      <div class="col-span-1 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <iconify-icon icon="solar:users-group-rounded-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-slate-900 mb-2">Client CRM</h3>
        <p class="text-sm text-slate-500 mb-6">Track progress, injuries, PRs, and notes in one unified view. Everything references this context automatically.</p>

        <!-- Mini UI -->
        <div class="mt-auto rounded-lg border border-slate-100 bg-slate-50 p-3 space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-xs font-medium text-slate-700">Check-in Status</span>
            <span class="text-[10px] font-medium bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full">Completed</span>
          </div>
          <div class="w-full bg-slate-200 h-1.5 rounded-full overflow-hidden">
            <div class="bg-indigo-500 h-full w-3/4 rounded-full"></div>
          </div>
        </div>
      </div>

      <!-- Feature 3: Custom Branding -->
      <div class="col-span-1 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-700">
          <iconify-icon icon="solar:ruler-pen-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-slate-900 mb-2">Custom App Branding</h3>
        <p class="text-sm text-slate-500 mb-6">Your clients interact with your brand, not ours. Customize colors, logos, and onboarding.</p>

        <!-- Mini UI Custom Settings -->
        <div class="mt-auto space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs font-medium text-slate-700">Primary Color</span>
            <div class="flex gap-1">
              <div class="w-4 h-4 rounded-full bg-indigo-600 ring-2 ring-indigo-100"></div>
              <div class="w-4 h-4 rounded-full bg-slate-900"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs font-medium text-slate-700">Push Notifications</span>
            <!-- Custom Toggle -->
            <div class="relative inline-block w-8 mr-2 align-middle select-none transition duration-200 ease-in">
              <input type="checkbox" name="toggle" id="toggle1" checked class="toggle-checkbox absolute block w-4 h-4 rounded-full bg-white border-4 appearance-none cursor-pointer border-indigo-600 transition-all right-0 z-10" />
              <label for="toggle1" class="toggle-label block overflow-hidden h-4 rounded-full bg-indigo-600 cursor-pointer transition-colors"></label>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 4: Automated Analytics (Large Span) -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm flex flex-col md:flex-row items-center gap-8 overflow-hidden">
        <div class="flex-1">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600">
            <iconify-icon icon="solar:chart-square-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
          </div>
          <h3 class="text-2xl font-medium tracking-tight text-slate-900 mb-2">Automated Analytics</h3>
          <p class="text-sm text-slate-500 mb-4">No more spreadsheets. WAGMI automatically charts volume, intensity, and compliance. See who's crushing it and who needs a nudge at a glance.</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-center gap-2 text-sm text-slate-600"><iconify-icon icon="solar:check-circle-linear" class="text-indigo-600"></iconify-icon> Volume landmarks tracked</li>
            <li class="flex items-center gap-2 text-sm text-slate-600"><iconify-icon icon="solar:check-circle-linear" class="text-indigo-600"></iconify-icon> Automated macro tracking</li>
          </ul>
        </div>

        <!-- Chart visual mock -->
        <div class="w-full md:w-1/2 h-40 flex items-end justify-between gap-2 px-4 border-b border-l border-slate-100 pb-2 relative">
          <!-- Y axis labels -->
          <div class="absolute left-0 top-0 bottom-0 flex flex-col justify-between text-[8px] text-slate-400 py-2 -ml-4">
            <span>100</span>
            <span>50</span>
            <span>0</span>
          </div>
          <!-- Bars -->
          <div class="w-full bg-indigo-100 rounded-t-sm h-[40%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-1/2 rounded-t-sm"></div></div>
          <div class="w-full bg-indigo-100 rounded-t-sm h-[60%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-[60%] rounded-t-sm"></div></div>
          <div class="w-full bg-indigo-100 rounded-t-sm h-[50%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-[40%] rounded-t-sm"></div></div>
          <div class="w-full bg-indigo-100 rounded-t-sm h-[80%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-[70%] rounded-t-sm"></div></div>
          <div class="w-full bg-indigo-100 rounded-t-sm h-[70%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-[80%] rounded-t-sm"></div></div>
          <div class="w-full bg-indigo-100 rounded-t-sm h-[90%] relative hover:bg-indigo-200 transition-colors"><div class="absolute inset-x-0 bottom-0 bg-indigo-600 h-[90%] rounded-t-sm"></div></div>
        </div>
      </div>

    </div>
  </div>
</section>
