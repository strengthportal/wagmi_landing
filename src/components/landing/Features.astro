---
---

<section id="features" class="bg-parchment-alt py-24 md:py-32 border-t border-warm-border">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-medium tracking-tight text-ink md:text-4xl text-balance">
          Powerful features.<br />Zero bloat.
        </h2>
        <p class="mt-4 text-lg text-ink-muted">
          Everything you need to run a modern coaching business, stripped of the complexity that slows you down.
        </p>
      </div>
      <div class="mt-6 md:mt-0">
        <a href="#" class="inline-flex items-center gap-2 text-sm font-medium text-cobalt hover:text-cobalt-dark">
          View all features <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">

      <!-- Feature 1: Large Span — Smart Structuring Engine -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-warm-border bg-card p-8 shadow-sm flex flex-col justify-between overflow-hidden relative">
        <div class="max-w-md relative z-10">
          <div class="inline-flex items-center rounded-full border border-warm-border bg-cobalt-soft px-2.5 py-0.5 text-xs font-medium text-cobalt mb-4">Core Innovation</div>
          <h3 class="text-2xl font-medium tracking-tight text-ink mb-2">Program at the Speed of Thought</h3>
          <p class="text-sm text-ink-muted mb-6">Write workouts however you think — shorthand, full sentences, whatever. WAGMI structures it instantly into trackable programs. Just write and go.</p>
        </div>

        <!-- Speed visual: raw input → structured output -->
        <div class="mt-6 rounded-xl border border-warm-border bg-parchment-alt overflow-hidden w-full shadow-sm relative z-10">
          <!-- Raw input -->
          <div class="px-4 py-3 bg-card border-b border-warm-border">
            <p class="text-[10px] font-medium text-ink-muted uppercase tracking-widest mb-1.5">You type</p>
            <p class="text-xs font-mono text-ink-muted">bench 3x8, cable rows 3x10, lat raises 4x15</p>
          </div>
          <!-- Speed indicator -->
          <div class="flex items-center gap-3 px-4 py-2 bg-cobalt-soft border-b border-warm-border">
            <iconify-icon icon="solar:bolt-bold" class="text-cobalt text-sm shrink-0"></iconify-icon>
            <div class="flex-1 h-1 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-3/4 bg-cobalt rounded-full"></div>
            </div>
            <span class="text-[10px] font-semibold text-cobalt shrink-0">0.3s</span>
          </div>
          <!-- Structured output -->
          <div class="divide-y divide-warm-border">
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-xs font-medium text-ink">Bench Press</span>
              <span class="text-[10px] text-ink-muted">3 sets × 8 reps</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-xs font-medium text-ink">Seated Cable Rows</span>
              <span class="text-[10px] text-ink-muted">3 sets × 10 reps</span>
            </div>
            <div class="flex items-center justify-between px-4 py-2.5">
              <span class="text-xs font-medium text-ink">DB Lateral Raises</span>
              <span class="text-[10px] text-ink-muted">4 sets × 15 reps</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 2: Powerful Client Management -->
      <div class="col-span-1 rounded-2xl border border-warm-border bg-card p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-parchment-alt text-ink">
          <iconify-icon icon="solar:users-group-rounded-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-ink mb-2">Powerful Client Management</h3>
        <p class="text-sm text-ink-muted mb-6">Track progress, injuries, PRs, and notes in one unified view. Everything your client needs, organized so you never have to dig.</p>

        <!-- Mini UI: client profile card -->
        <div class="mt-auto rounded-lg border border-warm-border bg-parchment-alt overflow-hidden">
          <div class="flex items-center gap-3 px-3 py-2.5 border-b border-warm-border">
            <div class="h-7 w-7 rounded-full bg-cobalt-soft flex items-center justify-center text-xs font-medium text-cobalt shrink-0">S</div>
            <div>
              <p class="text-xs font-medium text-ink">Sarah M.</p>
              <p class="text-[10px] text-ink-muted">Hypertrophy Block · Week 3</p>
            </div>
          </div>
          <div class="flex gap-1.5 px-3 py-2 border-b border-warm-border">
            <span class="text-[9px] font-medium bg-amber-50 text-amber-700 border border-amber-100 px-1.5 py-0.5 rounded-full">Knee sensitivity</span>
            <span class="text-[9px] font-medium bg-parchment-alt text-ink-muted px-1.5 py-0.5 rounded-full border border-warm-border">DB only</span>
          </div>
          <div class="grid grid-cols-2 divide-x divide-warm-border px-0">
            <div class="px-3 py-2">
              <p class="text-[9px] text-ink-muted uppercase tracking-wide">Squat PR</p>
              <p class="text-xs font-semibold text-ink">185 lb</p>
            </div>
            <div class="px-3 py-2">
              <p class="text-[9px] text-ink-muted uppercase tracking-wide">Bench PR</p>
              <p class="text-xs font-semibold text-ink">115 lb</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3: Exercise & Workout Libraries -->
      <div class="col-span-1 rounded-2xl border border-warm-border bg-card p-8 shadow-sm flex flex-col">
        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-parchment-alt text-ink">
          <iconify-icon icon="solar:notebook-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </div>
        <h3 class="text-xl font-medium tracking-tight text-ink mb-2">Your Exercises, Your Programs</h3>
        <p class="text-sm text-ink-muted mb-6">Build a custom exercise library tailored to how you coach. Save workout templates, remix them per client, and program weeks in minutes — not hours.</p>

        <!-- Mini UI: exercise list -->
        <div class="mt-auto rounded-lg border border-warm-border bg-parchment-alt overflow-hidden">
          <div class="flex items-center justify-between px-3 py-2 border-b border-warm-border">
            <span class="text-xs font-medium text-ink">Romanian Deadlift</span>
            <span class="text-[10px] text-ink-muted">Hinge</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2 border-b border-warm-border">
            <span class="text-xs font-medium text-ink">Landmine Press</span>
            <span class="text-[10px] text-ink-muted">Push</span>
          </div>
          <div class="flex items-center justify-between px-3 py-2">
            <span class="text-xs font-medium text-cobalt">+ Save as Template</span>
            <iconify-icon icon="solar:diskette-linear" class="text-dusty text-sm"></iconify-icon>
          </div>
        </div>
      </div>

      <!-- Feature 4: Mobile Workout Tracking (Large Span) -->
      <div class="col-span-1 md:col-span-2 rounded-2xl border border-warm-border bg-card p-8 shadow-sm flex flex-col md:flex-row items-center gap-8 overflow-hidden">
        <div class="flex-1">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-cobalt-soft text-cobalt">
            <iconify-icon icon="solar:smartphone-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
          </div>
          <h3 class="text-2xl font-medium tracking-tight text-ink mb-2">Track Workouts Anywhere</h3>
          <p class="text-sm text-ink-muted mb-4">Trainers and clients both get a mobile app for real-time workout logging. Sets, reps, RPE — captured in the moment, synced instantly.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-ink-muted"><iconify-icon icon="solar:check-circle-linear" class="text-cobalt"></iconify-icon> Real-time set logging</li>
            <li class="flex items-center gap-2 text-sm text-ink-muted"><iconify-icon icon="solar:check-circle-linear" class="text-cobalt"></iconify-icon> RPE &amp; notes per set</li>
            <li class="flex items-center gap-2 text-sm text-ink-muted"><iconify-icon icon="solar:check-circle-linear" class="text-cobalt"></iconify-icon> Instant sync across devices</li>
          </ul>
        </div>

        <!-- Phone frame mock -->
        <div class="w-full md:w-auto shrink-0 flex justify-center">
          <div class="w-44 rounded-3xl border-4 border-ink bg-card shadow-xl overflow-hidden">
            <!-- Phone notch -->
            <div class="bg-ink h-5 flex items-center justify-center">
              <div class="w-12 h-1.5 bg-ink-muted rounded-full"></div>
            </div>
            <!-- Screen content -->
            <div class="p-3 space-y-2">
              <p class="text-[9px] font-semibold text-ink-muted uppercase tracking-widest">Day 1 · Upper</p>
              <!-- Exercise row -->
              <div class="rounded-md bg-parchment-alt border border-warm-border px-2.5 py-2">
                <p class="text-[10px] font-medium text-ink mb-1.5">Bench Press</p>
                <div class="space-y-1">
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-ink-muted">Set 1 · 135 lb × 8</span>
                    <iconify-icon icon="solar:check-circle-bold" class="text-emerald-500 text-xs"></iconify-icon>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-ink-muted">Set 2 · 135 lb × 8</span>
                    <iconify-icon icon="solar:check-circle-bold" class="text-emerald-500 text-xs"></iconify-icon>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] text-ink-muted">Set 3 · — </span>
                    <div class="w-3 h-3 rounded-full border border-warm-border"></div>
                  </div>
                </div>
              </div>
              <!-- Next exercise -->
              <div class="rounded-md border border-warm-border px-2.5 py-2 opacity-50">
                <p class="text-[10px] font-medium text-ink">Cable Rows</p>
                <p class="text-[9px] text-ink-muted mt-0.5">3 sets × 10-12</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
