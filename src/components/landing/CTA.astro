---
---

<section id="waitlist" class="py-24 md:py-32 bg-white">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-10 md:p-16 shadow-sm relative overflow-hidden">
      <!-- Decorative background elements -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-50 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-cyan-50 rounded-full blur-3xl opacity-50"></div>

      <div class="relative z-10">
        <h2 class="text-3xl font-medium tracking-tight text-slate-900 md:text-4xl">
          Ready to get your time back?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-slate-500">
          Join independent trainers who are scaling their business without scaling their screen time. Request early access today.
        </p>

        <form class="mx-auto mt-8 flex w-full max-w-md flex-col gap-3 sm:flex-row">
          <input
            type="email"
            placeholder="coach@example.com"
            required
            class="flex h-12 w-full rounded-md border border-slate-200 bg-white px-4 py-2 text-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 shadow-sm"
          />
          <button
            type="submit"
            class="inline-flex h-12 shrink-0 items-center justify-center rounded-md bg-indigo-600 px-6 text-sm font-medium text-white transition-colors hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 focus:ring-offset-slate-50 w-full sm:w-auto"
          >
            Request Access
          </button>
        </form>
        <p class="mt-4 text-xs text-slate-400">Limited spots available in the current beta cohort.</p>
      </div>
    </div>
  </div>
</section>
